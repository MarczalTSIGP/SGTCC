<tr>
  <%= render 'shared/documents/tbody', document: document, show_path: academics_document_path(document) %>
  <td>
    <% unless document.academic_signed?(current_academic) %>
      <%= link_to edit_academics_tso_request_path(document) do %>
        <i class="fe fe-edit" data-controller="ui--tooltip" title="Editar justificativa"></i>
      <% end %>

      <%= link_to academics_tso_request_path(document),
                  data: { turbo_method: :delete, turbo_confirm: t('prompt.confirm') },
                  class: 'destroy' do %>
        <i class="fe fe-trash" data-controller="ui--tooltip" title="Deletar"></i>
      <% end %>
    <% end %>
  </td>
</tr>
