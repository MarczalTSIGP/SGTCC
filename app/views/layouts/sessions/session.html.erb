<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">

  <title>
    <%= full_title(yield(:head_title)) %>
  </title>
	
  <%= stylesheet_link_tag 'public/application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_importmap_tags %>

  <%= favicon_link_tag %>
  <%= csrf_meta_tags %>
</head>

<body id="<%= controller_name %>-<%= action_name %>" style="padding-top: 0px">

<div id="app" class="page">
  <div class="page-single">
    <div class="container-fluid">

      <div class="row">
        <div class="col col-login mx-auto">

          <div class="text-center mb-6">
            <%= image_tag("tsi.png", alt: "logo-tsi", class: 'header-brand-img') %>
          </div>

          <div class="card card-body p-6">
            <%= render Flash::MessageComponent.new %>
            <%= render 'shared/sweet_alert' %>

            <div class="card-title">
              <h4 class="text-center">
                <%= yield :title %>
              </h4>
            </div>

            <%= yield %>

          </div> <!-- .card -->
        </div>
      </div> <!-- .row -->
    </div> <!-- .container -->

  </div>
</div>
</body>
</html>
