<span class="sidebar-heading">
  <i class="fas fa-folder mt-2 mr-2"></i>
  <%= t('views.sidebar.documents.index') %>
</span>

<%= yield(:document_review) %>

<%= active_link_to(pending_path,
		   active: send("#{resource}_documents_pending_active_link?"),
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2 mt-2">
    <i class="fas fa-file-signature"></i>
  </span>
  <%= t('views.sidebar.documents.pending') %>
<% end %>

<%= active_link_to(signed_path,
		   active: send("#{resource}_documents_signed_active_link?"),
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2 mt-2">
    <i class="fas fa-file-contract"></i>
  </span>
  <%= t('views.sidebar.documents.signed') %>
<% end %>
