<span class="sidebar-heading">
   <i class="fas fa-user-cog mr-2"></i>
   <%= t('views.sidebar.responsible') %>
</span>

<%= active_link_to(responsible_root_path, active: :exact, class: 'list-group-item list-group-item-action') do %>
   <span class="icon mr-2">
      <i class="fas fa-home"></i>
   </span>
   <%= t('breadcrumbs.homepage') %>
<% end %>

<%= active_link_to(responsible_academics_path, class: 'list-group-item list-group-item-action') do %>
   <span class="icon mr-2">
      <i class="fas fa-user-graduate"></i>
   </span>
   <%= t('breadcrumbs.academics.index') %>
<% end %>

<%= active_link_to(responsible_professors_path, class: 'list-group-item list-group-item-action') do %>
   <span class="icon mr-2">
      <i class="fas fa-chalkboard-teacher"></i>
   </span>
   <%= t('breadcrumbs.professors.index') %>
<% end %>

<%= active_link_to(responsible_external_members_path, class: 'list-group-item list-group-item-action') do %>
   <span class="icon mr-2">
      <i class="fas fa-users"></i>
   </span>
   <%= t('breadcrumbs.external_members.index') %>
<% end %>

<%= active_link_to(responsible_institutions_path, class: 'list-group-item list-group-item-action') do %>
   <span class="icon mr-2">
      <i class="fas fa-university"></i>
   </span>
   <%= t('breadcrumbs.institutions.index') %>
<% end %>

<%= active_link_to(responsible_base_activities_tcc_one_path,
		   active: responsible_base_activities_active_link?,
		   class: 'list-group-item list-group-item-action') do %>
   <span class="icon mr-2">
      <i class="fas fa-file-alt"></i>
   </span>
   <%= t('breadcrumbs.base_activities.index') %>
<% end %>

<%= active_link_to(responsible_calendars_tcc_one_path,
		   active: responsible_calendars_active_link?,
		   class: 'list-group-item list-group-item-action') do %>
   <span class="icon mr-2">
      <i class="far fa-calendar-plus"></i>
   </span>
   <%= t('breadcrumbs.calendars.index') %>
<% end %>

<% if Calendar.current_by_tcc_one %>
   <%= active_link_to(responsible_calendar_activities_path(Calendar.current_by_tcc_one.id),
		     active: responsible_current_activities_tcc_one_active_link?,
		     class: 'list-group-item list-group-item-action') do %>
      <span class="icon mr-2">
         <i class="far fa-file-alt"></i>
      </span>
      <%= t('breadcrumbs.tcc.one.calendar', calendar: current_calendar_title) %>
   <% end %>
<% end %>

<% if Calendar.current_by_tcc_two %>
   <%= active_link_to(responsible_calendar_activities_path(Calendar.current_by_tcc_two.id),
		     active: responsible_current_activities_tcc_two_active_link?,
		     class: 'list-group-item list-group-item-action') do %>
      <span class="icon mr-2">
         <i class="far fa-file-alt"></i>
      </span>
      <%= t('breadcrumbs.tcc.two.calendar', calendar: current_calendar_title) %>
   <% end %>
<% end %>

