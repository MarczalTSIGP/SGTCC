<span class="sidebar-heading">
  <i class="fas fa-sliders-h mr-2"></i>
  <%= t('views.sidebar.site') %>
</span>

<%= active_link_to(responsible_pages_path,
                   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-pencil-alt"></i>
  </span>
  <%= t('breadcrumbs.site.pages') %>
<% end %>

<%= active_link_to(responsible_pages_order_path,
                   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-sort"></i>
  </span>
  <%= t('breadcrumbs.site.menu_order') %>
<% end %>

<%= active_link_to(responsible_images_path,
                   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="far fa-images"></i>
  </span>
  <%= t('breadcrumbs.site.images') %>
<% end %>

<%= active_link_to(responsible_attached_documents_path,
                   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="far fa-folder-open"></i>
  </span>
  <%= t('breadcrumbs.site.attached_documents') %>
<% end %>

<% if Site.first %>
  <%= active_link_to(edit_responsible_site_path(Site.first),
                     class: 'list-group-item list-group-item-action') do %>
    <span class="icon mr-2">
      <i class="fas fa-cogs"></i>
    </span>
    <%= t('breadcrumbs.site.configs') %>
  <% end %>
<% end %>
