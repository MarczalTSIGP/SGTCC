<span class="sidebar-heading">
  <i class="fas fa-users-cog mr-2"></i>
  <%= t('views.sidebar.tcc_one') %>
</span>

<%= active_link_to(tcc_one_professors_root_path,
		   active: :exact,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-home"></i>
  </span>
  <%= t('breadcrumbs.homepage') %>
<% end %>

<% if Calendar.current_by_tcc_one %>
  <%= active_link_to(tcc_one_professors_calendar_activities_path(Calendar.current_by_tcc_one&.id),
		     active: tcc_one_professors_activities_tcc_one_active_link?,
		     class: 'list-group-item list-group-item-action') do %>
    <span class="icon mr-2">
      <i class="far fa-file-alt"></i>
    </span>
    <%= t('breadcrumbs.tcc.one.calendar', calendar: current_calendar_title) %>
  <% end %>
<% end %>

<%= active_link_to(tcc_one_professors_calendar_orientations_path(Calendar.current_by_tcc_one&.id),
		   active: tcc_one_professors_orientations_tcc_one_active_link?,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-file-code"></i>
  </span>
  <%= t('breadcrumbs.orientations.tcc.one.calendar', calendar: current_calendar_title) %>
<% end %>

<%= active_link_to(tcc_one_professors_calendars_tcc_one_path,
		   active: tcc_one_professors_calendars_active_link?,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="far fa-calendar-plus"></i>
  </span>
  <%= t('breadcrumbs.calendars.index') %>
<% end %>

<%= active_link_to(tcc_one_professors_examination_boards_path,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-user-friends"></i>
  </span>
  <%= t('breadcrumbs.examination_boards.index') %>
<% end %>
