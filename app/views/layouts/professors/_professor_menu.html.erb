<span class="sidebar-heading">
  <i class="fas fa-users mr-2"></i>
  <%= t('views.sidebar.advisor') %>
</span>

<%= active_link_to(professors_root_path,
		   active: :exact,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-home"></i>
  </span>
  <%= t('breadcrumbs.homepage') %>
<% end %>

<% if Calendar.current_by_tcc_one %>
  <%= active_link_to(professors_calendar_activities_path(Calendar.current_by_tcc_one.id),
		     class: 'list-group-item list-group-item-action') do %>
    <span class="icon mr-2">
      <i class="far fa-file-alt"></i>
    </span>
    <%= t('breadcrumbs.tcc.one.calendar', calendar: current_calendar_title) %>
  <% end %>
<% end %>

<% if Calendar.current_by_tcc_two %>
  <%= active_link_to(professors_calendar_activities_path(Calendar.current_by_tcc_two.id),
		     class: 'list-group-item list-group-item-action') do %>
    <span class="icon mr-2">
      <i class="far fa-file-alt"></i>
    </span>
    <%= t('breadcrumbs.tcc.two.calendar', calendar: current_calendar_title) %>
  <% end %>
<% end %>

<%= active_link_to(professors_orientations_tcc_one_path,
		   active: professors_orientations_active_link?,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-file-code"></i>
  </span>
  <%= t('breadcrumbs.orientations.tcc.calendar', calendar: current_calendar_title) %>
<% end %>

<%= active_link_to(professors_orientations_history_path,
		   active: professors_orientations_history_active_link?,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="far fa-folder"></i>
  </span>
  <%= t('breadcrumbs.history') %>
<% end %>

<%= active_link_to(professors_meetings_path,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-user-check"></i>
  </span>
  <%= t('breadcrumbs.meetings.index') %>
<% end %>

<%= active_link_to(professors_examination_boards_path,
		   class: 'list-group-item list-group-item-action') do %>
  <span class="icon mr-2">
    <i class="fas fa-user-friends"></i>
  </span>
  <%= t('breadcrumbs.examination_boards.index') %>
<% end %>

<div class="sidebar-menu">
  <span class="sidebar-heading">
    <i class="fas fa-envelope-open mr-2"></i>
    <%= t('views.sidebar.requests') %>
  </span>

  <%= active_link_to(professors_requests_path,
		     class: 'list-group-item list-group-item-action') do %>
    <span class="icon mr-2">
      <i class="fas fa-exclamation-triangle"></i>
    </span>
    <%= t('breadcrumbs.documents.requests.tdo.advisor') %>
  <% end %>
</div>
