<%= render "shared/documents/base_term_layout", document: @document do %>
  <% advisor = @document.content.dig("advisor") %>
  <% academic = @document.content.dig("academic") %>
  <% orientation = @document.content.dig("orientation") %>
  <% request = @document.request || {} %>
  <p>
    Eu, <b><%= advisor.dig("name") %></b>, <%= advisor.dig("label") %> desta instituição,
    declaro para os devidos fins, desistir da orientação do trabalho de conclusão de
    curso intitulado <b><%= orientation.dig("title") %></b> do acadêmico
    <b><%= academic.dig("name") %></b>, RA <%= academic.dig("ra") %>.
  </p>
  <p>
    <b>Motivos da desistência</b>:
    <span>
      <div class="ml-4">
        <%= render "shared/markdown_reader", content: request.dig("requester", "justification") %>
      </div>
    </span>
  </p>
  <%= render "shared/documents/document_review",
      document: @document,
      can_edit: @document.professor_signed?(current_professor),
      has_permission: current_professor&.responsible? %>
<% end %>
