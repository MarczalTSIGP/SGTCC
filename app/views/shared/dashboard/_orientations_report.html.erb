<div class="card">
  <div class="card-header">
    <h3 class="card-title font-weight-bold">
      Orientações
    </h3>
  </div>

  <div class="card-body">
    <% calendar_data = data[:calendar_report] %>

    <% series = calendar_data.map do |item| 
      { name: item[:label], data: item[:data][:total] }
    end %>

    <% categories = calendar_data.first[:data][:years] rescue [] %>

    <%= render Charts::LineChartComponent.new(
      series: series,
      categories: categories,
      title: 'Ano/Semestre',
      options: {
        x_axis_title: 'Ano/Semestre',
        y_axis_title: 'Nº de orientações',
        colors: ['#85CC00', '#009900', '#FFFF00', '#FF9933', '#E35665', '#D9041A'],
        height: 350
      }
    ) %>
  </div>
</div>

