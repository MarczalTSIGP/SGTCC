<tr>
  <td><%= link_to professor.name, responsible_professor_path(professor) %></td>
  <td><%= professor.email %></td>
  <td>
    <%= link_to professor.lattes, target: '_blank' do %>
      <i class="fas fa-external-link-alt" data-controller="ui--tooltip" title="lattes"></i>
    <% end %>
  </td>
  <td><%= short_date(professor.created_at) %></td>
  <td>
    <%= render 'shared/links',
      resource_link: responsible_professor_path(professor),
      edit_link: edit_responsible_professor_path(professor) %>
  </td>
</tr>
