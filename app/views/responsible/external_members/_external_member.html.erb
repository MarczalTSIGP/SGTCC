<tr>
  <td><%= link_to external_member.name, responsible_external_member_path(external_member) %></td>
  <td><%= external_member.email %></td>
  <td>
    <%= link_to external_member.personal_page, target: '_blank' do %>
      <i class="fas fa-external-link-alt" data-controller="ui--tooltip" title="Página pessoal"></i>
    <% end %>
  </td>
  <td><%= short_date(external_member.created_at) %></td>
  <td>
    <%= render 'shared/links',
      resource_link: responsible_external_member_path(external_member),
      edit_link: edit_responsible_external_member_path(external_member) %>
  </td>
</tr>
