<% provide(:page_title) do %>
  <%= t("breadcrumbs.orientations.tcc.#{@orientation.current_calendar.tcc}.show",
        calendar: @orientation.academic_with_calendar) %>
<% end %>
<% provide(:head_title) do %>
  <%= t("breadcrumbs.orientations.tcc.#{@orientation.current_calendar.tcc}.show",
        calendar: @orientation.academic_with_calendar) %>
<% end %>

<%= provide(:edit_button) do %>
  <%= link_to t('simple_form.buttons.edit'),
    edit_responsible_orientation_path(@orientation),
    class: 'btn btn-primary ml-auto' %>
<% end %>

<%= provide(:orientation_options) do %>
  <div class="mt-3">
    <%= render 'shared/orientations/cancel', orientation: @orientation %>
  </div>

  <div class="clearfix"></div>
<% end %>

<%= render('shared/orientations/show', back_url: @back_url) %>
