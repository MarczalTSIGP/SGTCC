<% provide(:page_title, t('breadcrumbs.examination_boards.index')) %>
<% provide(:head_title, t('breadcrumbs.examination_boards.index')) %>

<div class="row">
   <div class="col-sm-12 col-lg-8 mb-2">
      <%= render 'shared/search', url: @search_url, search_term: params[:term] %>
   </div>

   <div class="col-sm-12 col-lg-4">
      <%= link_to(@new_url, class: 'btn btn-outline-primary d-block') do %>
         <i class="fe fe-plus"></i>
         <%= @link_name %>
      <% end %>
   </div>
</div>

<%= render ExaminationBoards::TableComponent.new(examination_boards: @examination_boards, namespace: :responsible) do |component| %>
  <% component.with_tabs do %>
    <%= render('tabs') %>
  <% end %>
<% end %>
